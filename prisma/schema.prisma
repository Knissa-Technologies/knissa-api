generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//
// ======================================================
// ENUMS
// ======================================================
//

enum UserRole {
  USER
  ADMIN
  SUPPORT
}

enum UserStatus {
  ACTIVE
  PENDING
  BLOCKED
}

enum WalletStatus {
  ACTIVE
  BLOCKED
  CLOSED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  EXCHANGE
  PAYMENT
  REFUND
  FEE
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

//
// ======================================================
// CORE
// ======================================================
//

model Country {
  id           String  @id @default(uuid())
  name         String
  isoCode      String  @unique
  phoneCode    String?
  currencyCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  currencies Currency[]

  @@map("countries")
}

model Currency {
  id String @id @default(uuid())

  code   String @unique
  name   String
  symbol String

  decimals Int @default(2)

  isActive Boolean @default(true)

  countryId String?

  country Country? @relation(fields: [countryId], references: [id])

  wallets Wallet[]

  baseRates  ExchangeRate[] @relation("BaseCurrency")
  quoteRates ExchangeRate[] @relation("QuoteCurrency")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("currencies")
}

//
// ======================================================
// IDENTITY
// ======================================================
//

model User {
  id String @id @default(uuid())

  firstName String
  lastName  String

  email String  @unique
  phone String?

  passwordHash String

  role UserRole @default(USER)

  status UserStatus @default(PENDING)

  countryId String?

  country Country? @relation(fields: [countryId], references: [id])

  wallets Wallet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

//
// ======================================================
// FINANCIAL
// ======================================================
//

model Wallet {
  id String @id @default(uuid())

  userId String

  currencyId String

  status WalletStatus @default(ACTIVE)

  user User @relation(fields: [userId], references: [id])

  currency Currency @relation(fields: [currencyId], references: [id])

  transactions Transaction[]

  ledgerEntries LedgerEntry[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([userId, currencyId])
  @@index([userId])
  @@index([currencyId])
  @@map("wallets")
}

model Transaction {
  id String @id @default(uuid())

  walletId String

  type TransactionType

  status TransactionStatus @default(PENDING)

  amount Decimal @db.Decimal(18, 2)

  description String?

  reference String? @unique

  wallet Wallet @relation(fields: [walletId], references: [id])

  ledgerEntries LedgerEntry[]

  fee Fee?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([walletId])
  @@index([status])
  @@index([type])
  @@map("transactions")
}

model LedgerEntry {
  id String @id @default(uuid())

  walletId String

  transactionId String

  type LedgerEntryType

  amount Decimal @db.Decimal(18, 2)

  wallet Wallet @relation(fields: [walletId], references: [id])

  transaction Transaction @relation(fields: [transactionId], references: [id])

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([transactionId])
  @@map("ledger_entries")
}

model ExchangeRate {
  id String @id @default(uuid())

  baseCurrencyId String

  quoteCurrencyId String

  rate Decimal @db.Decimal(18, 8)

  baseCurrency Currency @relation("BaseCurrency", fields: [baseCurrencyId], references: [id])

  quoteCurrency Currency @relation("QuoteCurrency", fields: [quoteCurrencyId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([baseCurrencyId, quoteCurrencyId])
  @@map("exchange_rates")
}

model Fee {
  id String @id @default(uuid())

  transactionId String @unique

  name String

  amount Decimal @db.Decimal(18, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id])

  createdAt DateTime @default(now())

  @@map("fees")
}
